  [current_flags]="Parámetros actuales"
  [shown]="Mostrados"
  [items]="Elementos"
  [files]="Archivos"
  [folders]="Carpetas"
  [size]="Tamaño"
  [sort]="Orden"
  [top]="Límite"
  [color]="Color"
  [theme]="Tema"
  [on]="activado"
  [off]="desactivado"
  [all]="todos"
  [tbl_idx]="#"
  [tbl_type]="TIPO"
  [tbl_file]="ARCHIVO"
  [tbl_modified]="MODIFICADO"
  [tbl_size]="TAMAÑO"
  [error]="Error:"
  [invalid_option]="Opción inválida"
  [invalid_directory]="directorio inválido"
  [invalid_sort]="valor inválido para --sort"
  [invalid_color]="valor inválido para --color"
  [invalid_theme]="valor inválido para --theme"
  [accepted_values]="Valores aceptados"
  [invalid_top]="el valor de --top debe ser numérico"
  [awk_missing]="el comando 'awk' no se encontró"
