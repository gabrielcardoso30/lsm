#!/usr/bin/env bash
#
# lsm — modern directory listing with summary cards.
# https://github.com/gabrielcardoso30/lsm
#
# Requires: bash 4+ (associative arrays), GNU find (for -printf), awk, tput,
# realpath. On macOS: `brew install findutils coreutils bash`. `find` is part
# of findutils; coreutils does NOT include it.

set -eu
# pipefail is intentionally NOT set: the `find | sort | head` pipeline below
# causes SIGPIPE in sort when --top truncates, which pipefail would surface as
# a fatal error. We still rely on `set -eu` plus explicit `mktemp`/`trap` for
# safety.
export LC_ALL=C.UTF-8

# ---------------------------------------------------------------------------
# i18n (see docs/adr/0003-i18n-with-message-tables.md)
# ---------------------------------------------------------------------------

declare -A MSG_EN MSG_PT MSG_ES

