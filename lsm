LSM_ACTIVE_LANG="en"

normalize_lang() {
  case "$1" in
    en|en_*|EN*) printf "en" ;;
    pt|pt_*|PT*) printf "pt" ;;
    es|es_*|ES*) printf "es" ;;
    *)           printf "en" ;;
  esac
}

t() {
  local key="$1"
  local val=""
  case "$LSM_ACTIVE_LANG" in
    pt) val="${MSG_PT[$key]:-}" ;;
    es) val="${MSG_ES[$key]:-}" ;;
    *)  val="${MSG_EN[$key]:-}" ;;
  esac
  [[ -z "$val" ]] && val="${MSG_EN[$key]:-$key}"
  printf '%s' "$val"
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

DIR="."
SORT_BY="time"
TOP_N=""
# Color emission mode (resolved to USE_COLOR below). `auto` emits ANSI only on a
# TTY; `always` forces it; `never` disables it. `--no-color` is an alias for
# `never`. See docs/specs/adaptive-color-theme.md (AC-22, AC-23).
COLOR_MODE="auto"
# Palette theme. Empty/`auto` triggers background detection; `dark`/`light`
# force a palette. Also settable via LSM_THEME (flag wins). See AC-24, AC-25.
THEME_FLAG=""
# Hidden entries are shown by default since v0.3.0; --no-hidden opts out.
# `--all` / `-a` are kept as silent no-ops for backward compatibility with
# v0.1.x / v0.2.x scripts. See docs/adr/0006-show-hidden-by-default.md.
SHOW_ALL=1
# When SHALLOW=1, the recursive `du -sb` on each subdirectory is skipped
# entirely. Directory rows render `-` for SIZE and contribute 0 to the
# summary Size total. See docs/adr/0007-parallel-du-and-shallow-flag.md.
SHALLOW=0
LANG_FLAG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --sort)
      SORT_BY="${2:-}"
      shift 2
      ;;
    --top)
      TOP_N="${2:-}"
      shift 2
      ;;
    --lang)
      LANG_FLAG="${2:-}"
      shift 2
      ;;
    --all|-a)
      # Default behavior since v0.3.0 — accepted silently for back-compat.
      SHOW_ALL=1
      shift
      ;;
    --no-hidden)
      SHOW_ALL=0
      shift
      ;;
    --shallow)
      SHALLOW=1
      shift
      ;;
    --theme)
      THEME_FLAG="${2:-}"
      shift 2
      ;;
    --color)
      COLOR_MODE="${2:-}"
      shift 2
      ;;
    --no-color)
      COLOR_MODE="never"
      shift
      ;;
    --)
      shift
      if [[ $# -gt 0 ]]; then DIR="$1"; shift; fi
      ;;
    -*)
      # Defer translation; we set the language before any user-facing output.
      LSM_ACTIVE_LANG="$(normalize_lang "${LSM_LANG:-${LANG:-en}}")"
      printf "\033[1;31m%s\033[0m %s: %s\n" "$(t error)" "$(t invalid_option)" "$1" >&2
      exit 1
      ;;
    *)
      DIR="$1"
      shift
      ;;
  esac
done

# Resolve active language: --lang > LSM_LANG > LANG/LC_ALL > en (AC-16e).
if [[ -n "$LANG_FLAG" ]]; then
  LSM_ACTIVE_LANG="$(normalize_lang "$LANG_FLAG")"
elif [[ -n "${LSM_LANG:-}" ]]; then
  LSM_ACTIVE_LANG="$(normalize_lang "$LSM_LANG")"
elif [[ -n "${LANG:-}" ]]; then
  LSM_ACTIVE_LANG="$(normalize_lang "$LANG")"
else
  LSM_ACTIVE_LANG="en"
fi

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------

if [[ ! -d "$DIR" ]]; then
  printf "\033[1;31m%s\033[0m %s: %s\n" "$(t error)" "$(t invalid_directory)" "$DIR" >&2
  exit 1
fi

if ! command -v awk >/dev/null 2>&1; then
  printf "\033[1;31m%s\033[0m %s.\n" "$(t error)" "$(t awk_missing)" >&2
  exit 1
fi

case "$SORT_BY" in
  time|name|size) ;;
  *)
    printf "\033[1;31m%s\033[0m %s: %s\n" "$(t error)" "$(t invalid_sort)" "$SORT_BY" >&2
    printf "%s: time, name, size\n" "$(t accepted_values)" >&2
    exit 1
    ;;
esac

case "$COLOR_MODE" in
  always|auto|never) ;;
  *)
    printf "\033[1;31m%s\033[0m %s: %s\n" "$(t error)" "$(t invalid_color)" "$COLOR_MODE" >&2
    printf "%s: always, auto, never\n" "$(t accepted_values)" >&2
    exit 1
    ;;
esac

case "$THEME_FLAG" in
  ''|dark|light|auto) ;;
  *)
    printf "\033[1;31m%s\033[0m %s: %s\n" "$(t error)" "$(t invalid_theme)" "$THEME_FLAG" >&2
    printf "%s: dark, light, auto\n" "$(t accepted_values)" >&2
    exit 1
    ;;
esac

if [[ -n "$TOP_N" && ! "$TOP_N" =~ ^[0-9]+$ ]]; then
  printf "\033[1;31m%s\033[0m %s.\n" "$(t error)" "$(t invalid_top)" >&2
  exit 1
fi

REAL_DIR="$(realpath "$DIR" 2>/dev/null || printf '%s' "$DIR")"

# Prefer GNU find (required for -printf). On macOS, install via `brew install
# coreutils` to get `gfind`. Fail loudly if neither has GNU semantics.
if command -v gfind >/dev/null 2>&1; then
  FIND="gfind"
else
  FIND="find"
fi
if ! "$FIND" / -maxdepth 0 -printf '' 2>/dev/null; then
  printf "\033[1;31m%s\033[0m %s requires GNU find (or 'gfind' from coreutils). " \
    "$(t error)" "lsm" >&2
  printf "On macOS: brew install coreutils.\n" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Inventory: count entries respecting --all
# ---------------------------------------------------------------------------

if [[ $SHOW_ALL -eq 1 ]]; then
  FIND_HIDDEN_FILTER=()
else
  FIND_HIDDEN_FILTER=(! -name '.*')
fi

TOTAL_ARQUIVOS=$("$FIND" "$DIR" -maxdepth 1 -mindepth 1 -type f "${FIND_HIDDEN_FILTER[@]}" -printf 'x\n' 2>/dev/null | wc -l)
TOTAL_PASTAS=$("$FIND" "$DIR" -maxdepth 1 -mindepth 1 -type d "${FIND_HIDDEN_FILTER[@]}" -printf 'x\n' 2>/dev/null | wc -l)
TOTAL_ITENS=$((TOTAL_ARQUIVOS + TOTAL_PASTAS))

# ---------------------------------------------------------------------------
# Collect rows, sort, optional top, render via awk
# ---------------------------------------------------------------------------

# Sort key fields in the intermediate record (pipe-separated):
#   1: kind (f|d)
#   2: mtime (epoch float)
#   3: name
#   4: pretty mtime (YYYY-MM-DD HH:MM:SS)
#   5: bytes (-1 for directories so they sort last on --sort size)

case "$SORT_BY" in
  time) SORT_ARGS=("-t|" "-nrk2,2") ;;
  name) SORT_ARGS=("-t|" "-k3,3f") ;;
  size) SORT_ARGS=("-t|" "-nrk5,5") ;;
esac

SEP_IN=$'\t'
TMP_FILE="$(mktemp)"
DIR_META_FILE="$(mktemp)"
DIR_SIZE_FILE="$(mktemp)"

# Cleanup removes the temp files and — critically — restores the terminal's
# stty settings if the OSC 11 background probe was interrupted mid-query while
# the terminal was in raw mode. INT/TERM are trapped too so Ctrl-C during that
# ~0.2s window never leaves the user's shell in raw mode (see AC-29 and the
# spec's threat model). LSM_STTY_SAVED is set only for the probe's duration.
LSM_STTY_SAVED=""
cleanup() {
  rm -f "$TMP_FILE" "$DIR_META_FILE" "$DIR_SIZE_FILE"
  [[ -n "$LSM_STTY_SAVED" ]] && stty "$LSM_STTY_SAVED" </dev/tty 2>/dev/null
  return 0
}
trap cleanup EXIT
trap 'cleanup; exit 130' INT
trap 'cleanup; exit 143' TERM

# Resolve the parallelism level for the directory `du -sb` pass. Capped at
# 8 because past that the bottleneck is filesystem stat IO, not CPU, and
# extra workers start hurting on spinning rust. Users can opt out of the
# cap by exporting LSM_JOBS explicitly. See ADR-0007.
resolve_jobs() {
  local n=""
  if [[ -n "${LSM_JOBS:-}" && "$LSM_JOBS" =~ ^[1-9][0-9]*$ ]]; then
    printf '%s' "$LSM_JOBS"
    return
  fi
  if command -v nproc >/dev/null 2>&1; then
    n="$(nproc 2>/dev/null || true)"
  fi
  if [[ -z "$n" ]] && command -v sysctl >/dev/null 2>&1; then
    n="$(sysctl -n hw.ncpu 2>/dev/null || true)"
  fi
  [[ -z "$n" || ! "$n" =~ ^[0-9]+$ ]] && n=4
  (( n > 8 )) && n=8
  (( n < 1 )) && n=1
  printf '%s' "$n"
}
JOBS="$(resolve_jobs)"

# Stage 1: cheap metadata pass for directories (no `du` runs here). Used by
# the join step below.
"$FIND" "$DIR" -maxdepth 1 -mindepth 1 -type d "${FIND_HIDDEN_FILTER[@]}" \
  -printf '%T@|%f|%TY-%Tm-%Td %TH:%TM:%TS|%p\n' 2>/dev/null > "$DIR_META_FILE"

# Stage 2: parallel `du -sb`. Skipped under --shallow (the dir SIZE cell
# will render `-` and dirs will contribute 0 bytes to the summary total).
# `xargs -0 -n1 -P` is portable across GNU and BSD userlands (Linux +
# macOS). See ADR-0007.
#
# `|| true` is load-bearing: `du -sb` exits 1 on any subtree with a
# permission-denied entry (e.g., root-owned container volumes under
# ~/projetos), and `xargs` aggregates that into exit 123. Without the
# guard, `set -e` would abort the script before the header is even
# printed. The lines `du` did manage to write are still captured — affected
# directories get a slightly underestimated size, which is the right
# graceful-degradation behavior for a read-only listing CLI.
if [[ $SHALLOW -eq 0 && -s "$DIR_META_FILE" ]]; then
  "$FIND" "$DIR" -maxdepth 1 -mindepth 1 -type d "${FIND_HIDDEN_FILTER[@]}" -print0 2>/dev/null \
    | xargs -0 -n1 -P"$JOBS" du -sb 2>/dev/null > "$DIR_SIZE_FILE" || true
fi

{
  "$FIND" "$DIR" -maxdepth 1 -mindepth 1 -type f "${FIND_HIDDEN_FILTER[@]}" \
    -printf 'f|%T@|%f|%TY-%Tm-%Td %TH:%TM:%TS|%s\n' 2>/dev/null

  # Stage 3: join metadata with parallel-du sizes. The size map is
  # pre-loaded from DIR_SIZE_FILE via getline so the main awk input is
  # purely the metadata file — this sidesteps the `NR == FNR` trap, which
  # breaks when the size file is empty (e.g., under --shallow or when
  # there are no subdirectories).
  if [[ -s "$DIR_META_FILE" ]]; then
    awk -v shallow="$SHALLOW" -v sizefile="$DIR_SIZE_FILE" '
      BEGIN {
        while ((getline line < sizefile) > 0) {
          tab = index(line, "\t")
          if (tab > 0) sizes[substr(line, tab + 1)] = substr(line, 1, tab - 1) + 0
        }
        close(sizefile)
      }
      {
        # Metadata records are mtime|name|date|path.
        n = split($0, m, "|")
        if (n < 4) next
        path = m[4]
        if (shallow == 1) bytes = -1
        else if (path in sizes) bytes = sizes[path]
        else bytes = 0
        printf "d|%s|%s|%s|%s\n", m[1], m[2], m[3], bytes
      }
    ' "$DIR_META_FILE"
  fi
} \
| sort "${SORT_ARGS[@]}" \
| { if [[ -n "$TOP_N" ]]; then head -n "$TOP_N"; else cat; fi; } \
| awk -F'|' -v sep="$SEP_IN" '
    BEGIN { total_bytes = 0; linhas = 0 }
    {
      kind = $1
      nome = $3
      gsub(/\t/, " ", nome)
      split($4, dt, "\\.")
      data = dt[1]

      bytes = $5 + 0
      if (kind == "d") nome = nome "/"
      # Negative bytes is the `--shallow` marker: directories rendered as
      # `-` and not counted toward the displayed total. See ADR-0007.
      if (bytes < 0) {
        tamanho = "-"
      } else {
        total_bytes += bytes
        if (bytes >= 1024*1024*1024)      tamanho = sprintf("%.2f GB", bytes/1024/1024/1024)
        else if (bytes >= 1024*1024)      tamanho = sprintf("%.2f MB", bytes/1024/1024)
        else if (bytes >= 1024)           tamanho = sprintf("%.2f KB", bytes/1024)
        else                              tamanho = sprintf("%d B", bytes)
      }

      printf "%s%s%s%s%s%s%s\n", kind, sep, nome, sep, data, sep, tamanho
      linhas++
    }
    END { printf "__SUMMARY__%s%d%s%d\n", sep, linhas, sep, total_bytes }
  ' > "$TMP_FILE"

EXIBIDOS=$(awk -F"$SEP_IN" '$1=="__SUMMARY__" {print $2}' "$TMP_FILE")
TOTAL_BYTES_EXIBIDOS=$(awk -F"$SEP_IN" '$1=="__SUMMARY__" {print $3}' "$TMP_FILE")
[[ -z "$EXIBIDOS" ]] && EXIBIDOS=0
[[ -z "$TOTAL_BYTES_EXIBIDOS" ]] && TOTAL_BYTES_EXIBIDOS=0

format_bytes_human() {
  awk -v bytes="$1" '
    BEGIN {
      if (bytes >= 1024*1024*1024)      printf "%.2f GB", bytes/1024/1024/1024
      else if (bytes >= 1024*1024)      printf "%.2f MB", bytes/1024/1024
      else if (bytes >= 1024)           printf "%.2f KB", bytes/1024
      else                              printf "%d B", bytes
    }'
}

TOTAL_EXIBIDO_HUMAN="$(format_bytes_human "$TOTAL_BYTES_EXIBIDOS")"

# ---------------------------------------------------------------------------
# Colors, theme detection and layout
#
# Color emission and palette are resolved here, just before any colored output.
# See docs/specs/adaptive-color-theme.md and docs/adr/0008-adaptive-color-theme.md.
# ---------------------------------------------------------------------------

# classify_luminance <color>
#   Maps a background color to "light" or "dark" by perceived luminance
#   (0.2126R + 0.7152G + 0.0722B over 0-255 channels; light when > 127, per
#   OQ-7). Accepts "#RRGGBB" and the OSC 11 reply form "rgb:RRRR/GGGG/BBBB"
#   (the high byte of each channel is used). Unparseable input prints nothing,
#   which the caller treats as inconclusive. Float math lives in awk because
#   bash has no floating point.
classify_luminance() {
  awk -v c="$1" '
    function hex2dec(s,   n, i, d, ch) {
      n = 0
      for (i = 1; i <= length(s); i++) {
        ch = tolower(substr(s, i, 1))
        d = index("0123456789abcdef", ch) - 1
        if (d < 0) return -1
        n = n * 16 + d
      }
      return n
    }
    BEGIN {
      r = -1; g = -1; b = -1
      if (c ~ /^#[0-9A-Fa-f]{6}$/) {
        r = hex2dec(substr(c, 2, 2)); g = hex2dec(substr(c, 4, 2)); b = hex2dec(substr(c, 6, 2))
      } else if (c ~ /^rgb:[0-9A-Fa-f]+\/[0-9A-Fa-f]+\/[0-9A-Fa-f]+$/) {
        split(substr(c, 5), p, "/")
        # OSC 11 channels are usually 16-bit (4 hex digits); the leading two
        # digits are the 8-bit-equivalent high byte.
        r = hex2dec(substr(p[1], 1, 2)); g = hex2dec(substr(p[2], 1, 2)); b = hex2dec(substr(p[3], 1, 2))
      }
      if (r < 0 || g < 0 || b < 0) exit 0
      print (0.2126 * r + 0.7152 * g + 0.0722 * b > 127 ? "light" : "dark")
    }'
}

# classify_colorfgbg <COLORFGBG>
#   COLORFGBG is "fg;bg" or "fg;default;bg"; the background is the last field.
#   ANSI 0-6 and 8 are dark backgrounds, 7 and 15 are light. Anything else
#   (e.g. "default") prints nothing so detection falls through to OSC 11.
classify_colorfgbg() {
  local bg="${1##*;}"
  case "$bg" in
    0|1|2|3|4|5|6|8) printf 'dark' ;;
    7|15)            printf 'light' ;;
    *) ;;
  esac
}

# probe_osc11_bg
#   Best-effort OSC 11 query for the terminal background color. Prints the raw
#   "rgb:..." payload on success, nothing otherwise. Safety (see the spec's
#   threat model): a bounded read timeout means an unresponsive terminal cannot
#   hang lsm; the terminal's stty mode is saved and restored on every exit path;
#   the reply is read from /dev/tty (never stdout) and is discarded unless it
#   strictly matches the rgb form, so unsupported terminals leak nothing.
probe_osc11_bg() {
  local saved reply
  # Talk to the controlling terminal on a dedicated fd. Crucially we cannot use
  # `[ -t 1 ]` here: resolve_theme calls us inside a command substitution, where
  # fd 1 is the capture pipe, not the terminal. Opening /dev/tty directly is the
  # correct probe; the grouped redirection swallows the "no controlling tty"
  # error so CI and cron stay silent.
  { exec 3<>/dev/tty; } 2>/dev/null || return 0
  saved="$(stty -g <&3 2>/dev/null)" || { exec 3>&-; return 0; }
  # Publish the saved settings so the signal-safe cleanup() can restore them if
  # Ctrl-C lands inside the raw-mode window below.
  LSM_STTY_SAVED="$saved"
  stty raw -echo <&3 2>/dev/null || { LSM_STTY_SAVED=""; exec 3>&-; return 0; }
  printf '\033]11;?\007' >&3
  # Read until the BEL terminator, capped at 0.2s; the dark fallback covers a
  # slow or non-answering terminal.
  IFS= read -r -d $'\007' -t 0.2 reply <&3 || true
  stty "$saved" <&3 2>/dev/null || true
  LSM_STTY_SAVED=""
  exec 3>&-
  case "$reply" in
    *rgb:*)
      reply="rgb:${reply#*rgb:}"
      reply="${reply%%$'\033'*}"
      printf '%s' "$reply"
      ;;
  esac
}

# resolve_theme
#   Resolves the active palette to "dark" or "light". Precedence (AC-25):
#   --theme flag > LSM_THEME env > auto-detection > dark fallback. The
#   auto-detection chain is LSM_BG_RGB > COLORFGBG > OSC 11 (AC-27, AC-28).
resolve_theme() {
  case "$THEME_FLAG" in
    dark|light) printf '%s' "$THEME_FLAG"; return ;;
  esac
  case "${LSM_THEME:-}" in
    dark|light) printf '%s' "$LSM_THEME"; return ;;
  esac

  local guess=""
  [[ -n "${LSM_BG_RGB:-}" ]] && guess="$(classify_luminance "$LSM_BG_RGB")"
  [[ -z "$guess" && -n "${COLORFGBG:-}" ]] && guess="$(classify_colorfgbg "$COLORFGBG")"
  if [[ -z "$guess" ]]; then
    local bg; bg="$(probe_osc11_bg)"
    [[ -n "$bg" ]] && guess="$(classify_luminance "$bg")"
  fi
  printf '%s' "${guess:-dark}"
}

# Resolve effective color on/off from the requested mode (AC-22, AC-23).
case "$COLOR_MODE" in
  always) USE_COLOR=1 ;;
  never)  USE_COLOR=0 ;;
  *)      if [ -t 1 ]; then USE_COLOR=1; else USE_COLOR=0; fi ;;
esac

# Resolve the palette only when color is on; default stays "dark" otherwise.
THEME_RESOLVED="dark"
[[ $USE_COLOR -eq 1 ]] && THEME_RESOLVED="$(resolve_theme)"

C_LABEL=""; C_RESET=""
CARD_BORDER_COLOR=""; CARD_TITLE_COLOR=""; CARD_TITLE_BG=""
CARD_COL1_COLOR=""; CARD_COL2_COLOR=""; CARD_COL3_COLOR=""
HEADER_LINE_COLOR=""; HEADER_TITLE_COLOR=""; HEADER_PATH_COLOR=""
DIR_COLOR=""; FILE_COLOR=""; DATE_COLOR=""; SIZE_COLOR=""; HIDDEN_COLOR=""; ROW_BG_ALT=""

if [[ $USE_COLOR -eq 1 ]]; then
  C_RESET="\033[0m"
  if [[ "$THEME_RESOLVED" == "light" ]]; then
    # Light palette: dark foregrounds + light background fills, legible on a
    # light terminal. Mirrors the dark palette role-for-role (AC-26, AC-30).
    C_LABEL="\033[38;5;240m"
    CARD_BORDER_COLOR="\033[38;5;245m"
    CARD_TITLE_COLOR="\033[1;38;5;236m"
    CARD_TITLE_BG="\033[48;5;253m"
    CARD_COL1_COLOR="\033[38;5;94m"
    CARD_COL2_COLOR="\033[38;5;28m"
    CARD_COL3_COLOR="\033[38;5;90m"
    HEADER_LINE_COLOR="\033[38;5;245m"
    HEADER_TITLE_COLOR="\033[38;5;25m"
    HEADER_PATH_COLOR="\033[1;38;5;235m"
    DIR_COLOR="\033[38;5;26m"
    FILE_COLOR="\033[38;5;94m"
    DATE_COLOR="\033[38;5;28m"
    SIZE_COLOR="\033[38;5;90m"
    # Hidden gray for a light background: a mid gray (245) rather than the
    # dark theme's 244, so it stays subdued yet legible. See AC-30.
    HIDDEN_COLOR="\033[38;5;245m"
    ROW_BG_ALT="\033[48;5;254m"
  else
    # Dark palette: the v0.3.x values, byte-for-byte (AC-24).
    C_LABEL="\033[0;37m"
    CARD_BORDER_COLOR="\033[38;5;250m"
    CARD_TITLE_COLOR="\033[1;97m"
    CARD_TITLE_BG="\033[48;5;238m"
    CARD_COL1_COLOR="\033[38;5;229m"
    CARD_COL2_COLOR="\033[38;5;121m"
    CARD_COL3_COLOR="\033[38;5;225m"
    HEADER_LINE_COLOR="\033[38;5;238m"
    HEADER_TITLE_COLOR="\033[1;96m"
    HEADER_PATH_COLOR="\033[1;37m"
    DIR_COLOR="\033[38;5;75m"
    FILE_COLOR="\033[1;33m"
    DATE_COLOR="\033[1;32m"
    SIZE_COLOR="\033[1;35m"
    # Hidden entries (names starting with `.`) use a dim 256-color gray so
    # they remain visually subdued next to regular files/directories without
    # being invisible. See docs/adr/0006-show-hidden-by-default.md.
    HIDDEN_COLOR="\033[38;5;244m"
    ROW_BG_ALT="\033[48;5;236m"
  fi
fi

repeat_char() {
  printf "%*s" "$2" "" | tr " " "$1"
}

pad_right() {
  # UTF-8-aware right-padding. bash's `${#var}` counts characters under
  # LC_ALL=C.UTF-8, but `printf "%-Ns"` pads by BYTES on glibc — so labels
  # with multi-byte characters (â, í, ñ, ã, ç) ended up narrower than the
  # cell and broke card alignment. We compute the missing visual width as
  # `width - char_count` and emit exactly that many trailing spaces via
  # `%*s "" `, which sidesteps the byte/char ambiguity.
  local text="$1"
  local width="$2"
  local len="${#text}"
  if [[ "$len" -gt "$width" ]]; then
    printf "%s..." "${text:0:$((width-3))}"
  else
    printf "%s%*s" "$text" "$((width - len))" ""
  fi
}

# COLUMNS wins over tput so tests and pipes get deterministic layout.
TERM_WIDTH="${COLUMNS:-$(tput cols 2>/dev/null || printf 120)}"
MIN_WIDTH_3COL=110

LINE="$(repeat_char '-' "$TERM_WIDTH")"

printf "%b%s%b\n" "$HEADER_LINE_COLOR" "$LINE" "$C_RESET"
printf "%b %s%b %b|%b %b%s%b\n" \
  "$HEADER_TITLE_COLOR" "LSM" "$C_RESET" \
  "$HEADER_LINE_COLOR" "$C_RESET" \
  "$HEADER_TITLE_COLOR" "$(t subtitle)" "$C_RESET"
printf "%b %s%b %b%s%b\n" \
  "$C_LABEL" "$(t directory)" "$C_RESET" \
  "$HEADER_PATH_COLOR" "$REAL_DIR" "$C_RESET"
printf "%b%s%b\n\n" "$HEADER_LINE_COLOR" "$LINE" "$C_RESET"

print_card_separator_3() {
  local w="$1" sep
  sep="$(repeat_char '-' "$w")"
  printf "%b|-%s-|%b  %b|-%s-|%b  %b|-%s-|%b\n" \
    "$CARD_BORDER_COLOR" "$sep" "$C_RESET" \
    "$CARD_BORDER_COLOR" "$sep" "$C_RESET" \
    "$CARD_BORDER_COLOR" "$sep" "$C_RESET"
}

print_card_line_3() {
  local c1="$1" c2="$2" c3="$3" w="$4"
  printf "%b| %b%s%b %b|%b  %b| %b%s%b %b|%b  %b| %b%s%b %b|%b\n" \
    "$CARD_BORDER_COLOR" "$CARD_COL1_COLOR" "$(pad_right "$c1" "$w")" "$C_RESET" "$CARD_BORDER_COLOR" "$C_RESET" \
    "$CARD_BORDER_COLOR" "$CARD_COL2_COLOR" "$(pad_right "$c2" "$w")" "$C_RESET" "$CARD_BORDER_COLOR" "$C_RESET" \
    "$CARD_BORDER_COLOR" "$CARD_COL3_COLOR" "$(pad_right "$c3" "$w")" "$C_RESET" "$CARD_BORDER_COLOR" "$C_RESET"
}

color_label() {
  if [[ $USE_COLOR -eq 1 ]]; then
    t on
  else
    t off
  fi
}

# pad_label: same idea as pad_right but never truncates — used to align the
# `label : value` columns in the summary cards across languages where the
# longest label varies (e.g. "Tamanho" vs "Folders" vs "Carpetas").
pad_label() {
  local text="$1"
  local width="$2"
  local len="${#text}"
  printf "%s%*s" "$text" "$((width - len))" ""
}

# Compute the widest label per card column so the colons align in any
# language. Column 1: Shown/Items/Files/Folders/Size. Column 3: Sort/Top/Color/Theme.
__c1_labels=("$(t shown)" "$(t items)" "$(t files)" "$(t folders)" "$(t size)")
__c3_labels=("$(t sort)"  "$(t top)"   "$(t color)" "$(t theme)")
CARD_C1_LABEL_W=0
for __lbl in "${__c1_labels[@]}"; do
  (( ${#__lbl} > CARD_C1_LABEL_W )) && CARD_C1_LABEL_W=${#__lbl}
done
CARD_C3_LABEL_W=0
for __lbl in "${__c3_labels[@]}"; do
  (( ${#__lbl} > CARD_C3_LABEL_W )) && CARD_C3_LABEL_W=${#__lbl}
done
unset __c1_labels __c3_labels __lbl

if [[ "$TERM_WIDTH" -ge "$MIN_WIDTH_3COL" ]]; then
  CARD_INNER_WIDTH=30
  CARD_BORDER="+-$(repeat_char '-' "$CARD_INNER_WIDTH")-+"

  printf "%b%s%b  %b%s%b  %b%s%b\n" \
    "$CARD_BORDER_COLOR" "$CARD_BORDER" "$C_RESET" \
    "$CARD_BORDER_COLOR" "$CARD_BORDER" "$C_RESET" \
    "$CARD_BORDER_COLOR" "$CARD_BORDER" "$C_RESET"

  printf "%b| %b%b%s%b %b|%b  %b| %b%b%s%b %b|%b  %b| %b%b%s%b %b|%b\n" \
    "$CARD_BORDER_COLOR" "$CARD_TITLE_BG" "$CARD_TITLE_COLOR" "$(pad_right "$(t summary)" "$CARD_INNER_WIDTH")" "$C_RESET" "$CARD_BORDER_COLOR" "$C_RESET" \
    "$CARD_BORDER_COLOR" "$CARD_TITLE_BG" "$CARD_TITLE_COLOR" "$(pad_right "$(t available_flags)" "$CARD_INNER_WIDTH")" "$C_RESET" "$CARD_BORDER_COLOR" "$C_RESET" \
    "$CARD_BORDER_COLOR" "$CARD_TITLE_BG" "$CARD_TITLE_COLOR" "$(pad_right "$(t current_flags)" "$CARD_INNER_WIDTH")" "$C_RESET" "$CARD_BORDER_COLOR" "$C_RESET"

  print_card_separator_3 "$CARD_INNER_WIDTH"

  print_card_line_3 "$(pad_label "$(t shown)"   "$CARD_C1_LABEL_W") : $EXIBIDOS"             "--sort [time|name|size]"   "$(pad_label "$(t sort)"  "$CARD_C3_LABEL_W") : $SORT_BY"            "$CARD_INNER_WIDTH"
  print_card_line_3 "$(pad_label "$(t items)"   "$CARD_C1_LABEL_W") : $TOTAL_ITENS"          "--top N"                   "$(pad_label "$(t top)"   "$CARD_C3_LABEL_W") : ${TOP_N:-$(t all)}" "$CARD_INNER_WIDTH"
  print_card_line_3 "$(pad_label "$(t files)"   "$CARD_C1_LABEL_W") : $TOTAL_ARQUIVOS"       "--no-hidden"               "$(pad_label "$(t color)" "$CARD_C3_LABEL_W") : $(color_label)"    "$CARD_INNER_WIDTH"
  print_card_line_3 "$(pad_label "$(t folders)" "$CARD_C1_LABEL_W") : $TOTAL_PASTAS"         "--shallow"                 "$(pad_label "$(t theme)" "$CARD_C3_LABEL_W") : $THEME_RESOLVED"   "$CARD_INNER_WIDTH"
  print_card_line_3 "$(pad_label "$(t size)"    "$CARD_C1_LABEL_W") : $TOTAL_EXIBIDO_HUMAN"  "--theme dark|light|auto"   ""                                                                "$CARD_INNER_WIDTH"
  print_card_line_3 ""                                                                       "--color always|auto|never" ""                                                                "$CARD_INNER_WIDTH"
  print_card_line_3 ""                                                                       "--lang en|pt|es"           ""                                                                "$CARD_INNER_WIDTH"

  printf "%b%s%b  %b%s%b  %b%s%b\n\n" \
    "$CARD_BORDER_COLOR" "$CARD_BORDER" "$C_RESET" \
    "$CARD_BORDER_COLOR" "$CARD_BORDER" "$C_RESET" \
    "$CARD_BORDER_COLOR" "$CARD_BORDER" "$C_RESET"
else
  printf "%b%s%b\n" "$C_LABEL" "$(t summary)" "$C_RESET"
  printf "  %s : %s\n"     "$(t shown)"   "$EXIBIDOS"
  printf "  %s : %s\n"     "$(t items)"   "$TOTAL_ITENS"
  printf "  %s : %s\n"     "$(t files)"   "$TOTAL_ARQUIVOS"
  printf "  %s : %s\n"     "$(t folders)" "$TOTAL_PASTAS"
  printf "  %s : %s\n\n"   "$(t size)"    "$TOTAL_EXIBIDO_HUMAN"

  printf "%b%s%b\n" "$C_LABEL" "$(t available_flags)" "$C_RESET"
  printf "  --sort [time|name|size]\n"
  printf "  --top N\n"
  printf "  --no-hidden\n"
  printf "  --shallow\n"
  printf "  --theme dark|light|auto\n"
  printf "  --color always|auto|never\n"
  printf "  --lang en|pt|es\n\n"

  printf "%b%s%b\n" "$C_LABEL" "$(t current_flags)" "$C_RESET"
  printf "  %s : %s\n"   "$(t sort)"  "$SORT_BY"
  printf "  %s : %s\n"   "$(t top)"   "${TOP_N:-$(t all)}"
  printf "  %s : %s\n"   "$(t color)" "$(color_label)"
  printf "  %s : %s\n\n" "$(t theme)" "$THEME_RESOLVED"
fi

# ---------------------------------------------------------------------------
# Legend
#
# Shows a one-line key mapping the three name-column colors to their
# meaning (regular file / directory / hidden entry) right above the table.
# Suppressed under --no-color since the swatch words rely on ANSI to carry
# any signal.
# ---------------------------------------------------------------------------

if [[ $USE_COLOR -eq 1 ]]; then
  printf "%b%s%b  %b%s%b  %b%s%b  %b%s%b\n\n" \
    "$C_LABEL"       "$(t legend)"          "$C_RESET" \
    "$FILE_COLOR"    "$(t legend_file)"      "$C_RESET" \
    "$DIR_COLOR"     "$(t legend_directory)" "$C_RESET" \
    "$HIDDEN_COLOR"  "$(t legend_hidden)"    "$C_RESET"
fi

# ---------------------------------------------------------------------------
# Table
#
# Column alignment is done inline by awk (two-pass: collect, then render) so
# we do not depend on `column`. Earlier versions piped through `column -t -o`,
# which is GNU util-linux only; BSD column on macOS rejects -o and breaks the
# render mid-pipeline.
# ---------------------------------------------------------------------------

grep -v '^__SUMMARY__' "$TMP_FILE" \
| awk -F"$SEP_IN" \
    -v use_color="$USE_COLOR" \
    -v file_color="$FILE_COLOR" \
    -v dir_color="$DIR_COLOR" \
    -v hidden_color="$HIDDEN_COLOR" \
    -v date_color="$DATE_COLOR" \
    -v size_color="$SIZE_COLOR" \
    -v reset="$C_RESET" \
    -v bg_alt="$ROW_BG_ALT" \
    -v hdr_idx="$(t tbl_idx)" \
    -v hdr_type="$(t tbl_type)" \
    -v hdr_name="$(t tbl_file)" \
    -v hdr_date="$(t tbl_modified)" \
    -v hdr_size="$(t tbl_size)" '
  BEGIN {
    maxn = length(hdr_name)
    maxd = length(hdr_date)
    maxs = length(hdr_size)
    # Emoji icons render as 2 terminal cells but awk length() reports 1.
    # Hardcode a visual width of 2 for the icon, then take the larger of
    # that and the header label as the column width.
    icon_visual = 2
    type_w = (length(hdr_type) > icon_visual) ? length(hdr_type) : icon_visual
  }
  {
    kind[NR] = $1
    name[NR] = $2
    date_v[NR] = $3
    size_v[NR] = $4
    if (length($2) > maxn) maxn = length($2)
    if (length($3) > maxd) maxd = length($3)
    if (length($4) > maxs) maxs = length($4)
  }
  END {
    idx_w = length(hdr_idx)
    if (length("" NR) > idx_w) idx_w = length("" NR)

    printf "%-*s | %-*s | %s%-*s%s | %s%-*s%s | %s%-*s%s\n",
      idx_w, hdr_idx,
      type_w, hdr_type,
      file_color, maxn, hdr_name, reset,
      date_color, maxd, hdr_date, reset,
      size_color, maxs, hdr_size, reset
    sep_len = idx_w + type_w + maxn + maxd + maxs + 12
    for (i = 0; i < sep_len; i++) printf "-"
    printf "\n"

    for (r = 1; r <= NR; r++) {
      is_dir = (kind[r] == "d")
      icon = is_dir ? "📁" : "📄"
      # Hidden entries (names starting with `.`) override the dir/file
      # color with a dim gray so they read as "configuration / housekeeping"
      # rather than primary content. See ADR-0006.
      is_hidden = (substr(name[r], 1, 1) == ".")
      name_c = is_hidden ? hidden_color : (is_dir ? dir_color : file_color)
      bg = (r % 2 == 1) ? bg_alt : ""
      # Icon contributes 2 visual cells; pad with (type_w - icon_visual)
      # trailing spaces so the column lines up under the header.
      printf "%s%-*d%s | %s%s%*s%s | %s%s%-*s%s | %s%s%-*s%s | %s%s%-*s%s\n",
        bg, idx_w, r, reset,
        bg, icon, type_w - icon_visual, "", reset,
        bg, name_c, maxn, name[r], reset,
        bg, date_color, maxd, date_v[r], reset,
        bg, size_color, maxs, size_v[r], reset
    }
  }
'

# ---------------------------------------------------------------------------
# Footer
#
# Closing block that mirrors the header to give the output a clean visual
# boundary before the next shell prompt. Three lines: a divider, a recap
# line ("lsm · items: N · size: X · sort: Y"), another divider. Reuses the
# same line / title colors as the header for symmetry.
# ---------------------------------------------------------------------------

printf "\n%b%s%b\n" "$HEADER_LINE_COLOR" "$LINE" "$C_RESET"
# `shown` (post-`--top`) is the count that matches what the user just saw
# above; using `items` here would diverge from the table whenever `--top`
# truncates.
printf "%b %s%b %b·%b %s: %s %b·%b %s: %s %b·%b %s: %s %b·%b %s\n" \
  "$HEADER_TITLE_COLOR" "lsm" "$C_RESET" \
  "$HEADER_LINE_COLOR" "$C_RESET" \
  "$(t shown)" "$EXIBIDOS" \
  "$HEADER_LINE_COLOR" "$C_RESET" \
  "$(t size)" "$TOTAL_EXIBIDO_HUMAN" \
  "$HEADER_LINE_COLOR" "$C_RESET" \
  "$(t sort)" "$SORT_BY" \
  "$HEADER_LINE_COLOR" "$C_RESET" \
  "$(t footer_end)"
printf "%b%s%b\n" "$HEADER_LINE_COLOR" "$LINE" "$C_RESET"
